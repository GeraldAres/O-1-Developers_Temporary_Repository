{
  "manifest_version": 3,
  "name": "Shield Buddy Beta",
  "version": "0.1",
  "description": "Analyzes your Messenger messages locally to detect potentially harmful content, without sending any data outside your browser.",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.messenger.com/*"
  ],
  "action": {
    "default_popup": "pages/popup-router.html",
    "default_icon": "assets/final_icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.messenger.com/*"
      ],
      "js": ["scripts/content.js"]
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "web_accessible_resources": [ 
    {
      "resources": [ "assets/ed.png" ], 
      "matches": [ "https://*.messenger.com/*" ] 
    }
  ]
}